# ======================================================
# SECRETS_TO_PASTE.env.example
# Незаполненные секреты — вставь значения и запусти
# paste-secrets.sh (см. ниже), потом редеплой Vercel.
# ======================================================

# ------ 1. Apple Team ID (10 символов) ------
# Откуда: developer.apple.com/account → Membership → Team ID
APPLE_TEAM_ID=

# ------ 2. Android Release SHA-256 ------
# Откуда (вариант A): Play Console → App → Setup → App signing → SHA-256
# Откуда (вариант B): eas credentials --platform android
# Откуда (вариант C): keytool -list -v -keystore *.jks | grep SHA256
# Формат: AA:BB:CC:... (с двоеточиями) или AABBCC... (без) — оба работают
ANDROID_RELEASE_SHA256=

