# ============================================================
# FundingPro — Environment Variables Template
# Company: ООО «FUNDINGPRO», STIR 313 116 567, DGU No. 61712
# SECURITY: Never commit real secrets to version control
# ============================================================

# Convex — run `npx convex dev` to populate NEXT_PUBLIC_CONVEX_URL
NEXT_PUBLIC_CONVEX_URL="http://127.0.0.1:3210"
CONVEX_DEPLOYMENT=""
CONVEX_DEPLOY_KEY=""
# Shared secret for server-only Convex system actions (payments webhooks, etc.)
# Generate with: openssl rand -hex 32 — set the same value in Convex dashboard env
CONVEX_SYSTEM_SECRET=""

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
# Clerk Frontend API URL (from Clerk → Convex integration setup)
CLERK_JWT_ISSUER_DOMAIN="https://your-clerk-domain.clerk.accounts.dev"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="FundingPro"

# Analytics (optional)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Telegram digest (scripts/telegram-grants-digest.mjs)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Resend (email delivery) — https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxx"
RESEND_FROM_EMAIL="info@fundingpro.uz"

# AI Gateway
# AI DATA POLICY: personal data redaction layer is applied before any AI call
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
AI_PROVIDER="mock"
AI_DEFAULT_PROVIDER="mock"

# Rate Limiting (AI + auth API routes)
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="30"
AUTH_RATE_LIMIT_MAX="20"

# Admin (comma-separated emails)
ADMIN_EMAILS="admin@fundingpro.uz"
# Non-production only: allow any authenticated user into /admin (dev convenience)
ADMIN_BYPASS_DEV="false"

# Payments (Uzum Bank — enable only after sandbox credentials)
PAYMENTS_ENABLED=false
PAYMENT_INTEGRATION_STATUS=pending_integration
PAYMENT_PROVIDER=uzum
USD_UZS_RATE=12800

# Uzum Merchant API (inbound webhooks from Uzum Bank app)
UZUM_MERCHANT_SERVICE_ID=
UZUM_MERCHANT_LOGIN=
UZUM_MERCHANT_PASSWORD=
# Optional HMAC layer on merchant webhooks (Basic Auth is always required).
# When set, Uzum callbacks must include header x-uzum-signature (hex HMAC-SHA256 of raw JSON body).
# Generate with: openssl rand -hex 32
UZUM_WEBHOOK_SECRET=
# Legacy alias — prefer UZUM_WEBHOOK_SECRET
# PAYMENT_WEBHOOK_SECRET=

# Uzum Checkout API (card payment on website)
UZUM_CHECKOUT_BASE_URL=https://api.uzumbank.uz
UZUM_CHECKOUT_TERMINAL_ID=
UZUM_CHECKOUT_SECRET=
UZUM_CHECKOUT_RETURN_URL=http://localhost:3000/dashboard/subscription/return

# Expo push notifications (Convex pushNotifications.ts — optional but recommended for production)
EXPO_ACCESS_TOKEN=""

# Security
CORS_ALLOWED_ORIGINS="http://localhost:3000"

# Mobile App Links (production — set on Vercel)
# APPLE_TEAM_ID=
# ANDROID_RELEASE_SHA256=
