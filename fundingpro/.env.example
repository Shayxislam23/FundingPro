# Supabase — https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Database (via Supabase — Settings → Database → Connection string)
DATABASE_URL="postgresql://postgres:[password]@db.your-project-id.supabase.co:5432/postgres"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="FundingPro"

# AI Gateway
# TODO: configure AI provider credentials
# AI DATA POLICY: personal data redaction layer must be applied before any AI call
OPENAI_API_KEY="TODO"
ANTHROPIC_API_KEY="TODO"
AI_DEFAULT_PROVIDER="openai"  # "openai" or "anthropic"

# File Storage (private, no public URLs)
