# Database (PostgreSQL) — must be hosted in Uzbekistan
DATABASE_URL="postgresql://fundingpro:password@localhost:5432/fundingpro"

# Redis (Cache / BullMQ queue)
REDIS_URL="redis://localhost:6379"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="FundingPro"

# JWT Secrets — use strong random values in production
JWT_SECRET="CHANGE_ME_GENERATE_STRONG_SECRET"
JWT_REFRESH_SECRET="CHANGE_ME_GENERATE_STRONG_REFRESH_SECRET"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="30d"

# ZOOMRAD Integration
# TODO: obtain credentials from ZOOMRAD integration team
ZOOMRAD_APP_ID="TODO"
ZOOMRAD_APP_SECRET="TODO"
ZOOMRAD_WEBHOOK_SECRET="TODO"
ZOOMRAD_API_BASE_URL="TODO"

# AI Gateway
# TODO: configure AI provider credentials
# AI DATA POLICY: personal data redaction layer must be applied before any AI call
OPENAI_API_KEY="TODO"
ANTHROPIC_API_KEY="TODO"
AI_DEFAULT_PROVIDER="openai"  # "openai" or "anthropic"

# File Storage (private, no public URLs)
# TODO: configure private S3-compatible storage in Uzbekistan
STORAGE_BUCKET="fundingpro-documents"
STORAGE_ENDPOINT="TODO"
STORAGE_ACCESS_KEY="TODO"
STORAGE_SECRET_KEY="TODO"
STORAGE_REGION="uz-1"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="100"

# Security
CORS_ALLOWED_ORIGINS="http://localhost:3000"
