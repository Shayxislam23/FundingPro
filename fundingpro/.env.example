# ============================================================
# FundingPro — Environment Variables Template
# Company: ООО «FUNDINGPRO», STIR 313 116 567, DGU No. 61712
# SECURITY: Never commit real secrets to version control
# ============================================================

# Supabase — https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Database (via Supabase — Settings → Database → Connection string)
DATABASE_URL="postgresql://postgres:[password]@db.your-project-id.supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.your-project-id.supabase.co:5432/postgres"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="FundingPro"

# Analytics (optional)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Telegram digest (scripts/telegram-grants-digest.mjs)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Resend (email delivery) — https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxx"
RESEND_FROM_EMAIL="info@fundingpro.uz"

# AI Gateway
# AI DATA POLICY: personal data redaction layer is applied before any AI call
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
AI_PROVIDER="mock"
AI_DEFAULT_PROVIDER="mock"

# File Storage (Supabase Storage bucket `documents` — see supabase/migrations)
STORAGE_BUCKET="documents"

# Rate Limiting (AI routes)
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="30"

# Admin (comma-separated emails)
ADMIN_EMAILS="admin@fundingpro.uz"
# Non-production only: allow any authenticated user into /admin (dev convenience)
ADMIN_BYPASS_DEV="false"

# Payments (Uzum Bank — enable only after sandbox credentials)
PAYMENTS_ENABLED=false
PAYMENT_INTEGRATION_STATUS=pending_integration
PAYMENT_PROVIDER=uzum
USD_UZS_RATE=12800

# Uzum Merchant API (inbound webhooks from Uzum Bank app)
# Local sandbox E2E (npm run uzum:sandbox): use these test values + PAYMENTS_ENABLED=true
UZUM_MERCHANT_SERVICE_ID=
UZUM_MERCHANT_LOGIN=
UZUM_MERCHANT_PASSWORD=

# Uzum Checkout API (card payment on website)
UZUM_CHECKOUT_BASE_URL=https://api.uzumbank.uz
UZUM_CHECKOUT_TERMINAL_ID=
UZUM_CHECKOUT_SECRET=
UZUM_CHECKOUT_RETURN_URL=http://localhost:3000/dashboard/subscription/return

# Local PostgreSQL (optional — Docker on :5433, auth still via Supabase)
USE_LOCAL_DATABASE=false
LOCAL_DATABASE_URL="postgresql://fundingpro:fundingpro_dev@127.0.0.1:5433/fundingpro"

# Security
CORS_ALLOWED_ORIGINS="http://localhost:3000"
