# ============================================================
# FundingPro — Production / Preview Environment Template
# Company: ООО «FUNDINGPRO», STIR 313 116 567, DGU No. 61712
# Copy keys to Vercel Dashboard → Settings → Environment Variables
# NEVER commit real secrets to version control
# ============================================================

# --- Required (Production + Preview) ---

NEXT_PUBLIC_CONVEX_URL="https://your-deployment.convex.cloud"
CONVEX_DEPLOYMENT="prod:your-deployment"
CONVEX_DEPLOY_KEY=""

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_..."
CLERK_SECRET_KEY="sk_live_..."
CLERK_JWT_ISSUER_DOMAIN="https://your-clerk-domain.clerk.accounts.dev"

NEXT_PUBLIC_APP_URL="https://fundingpro.uz"
NEXT_PUBLIC_APP_NAME="FundingPro"

RESEND_API_KEY="re_xxxxxxxxx"
RESEND_FROM_EMAIL="info@fundingpro.uz"

ADMIN_EMAILS="info@fundingpro.uz"

# --- Recommended ---

AI_PROVIDER="mock"
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""

CORS_ALLOWED_ORIGINS="https://fundingpro.uz"

# --- Mobile App Links (.well-known on www.fundingpro.uz) ---

# Apple Developer Team ID (10 chars) — required for production Universal Links
APPLE_TEAM_ID=
# Android release signing cert SHA-256 (colon-free or with colons); comma-separated for multiple
ANDROID_RELEASE_SHA256=
# Optional — defaults match mobile/app.json
# IOS_BUNDLE_ID=uz.fundingpro.app
# ANDROID_PACKAGE=uz.fundingpro.app

# --- Payments (keep disabled until sandbox pass — see docs/PAYMENTS-OVERVIEW.md) ---

PAYMENTS_ENABLED=false
PAYMENT_PROVIDERS=uzum,payme,click
PAYMENT_INTEGRATION_STATUS=pending_integration
PAYMENT_PROVIDER=uzum
PAYMENT_RECONCILIATION_CONFIRMED=false
USD_UZS_RATE=12800
CONVEX_SYSTEM_SECRET=

UZUM_MERCHANT_SERVICE_ID=
UZUM_MERCHANT_LOGIN=
UZUM_MERCHANT_PASSWORD=
# Optional HMAC on merchant webhooks — see fundingpro/docs/UZUM-GO-LIVE.md
UZUM_WEBHOOK_SECRET=

UZUM_CHECKOUT_BASE_URL=https://api.uzumbank.uz
UZUM_CHECKOUT_TERMINAL_ID=
UZUM_CHECKOUT_SECRET=
UZUM_CHECKOUT_RETURN_URL=https://fundingpro.uz/dashboard/subscription/return
# Production webhook base for npm run uzum:webhooks
# UZUM_WEBHOOK_BASE_URL=https://fundingpro.uz

PAYME_MERCHANT_ID=
PAYME_MERCHANT_KEY=
PAYME_TEST_MODE=true
# PAYME_CHECKOUT_BASE_URL=https://checkout.test.paycom.uz

CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
# CLICK_MERCHANT_USER_ID=

# --- Do NOT set in production ---

# ADMIN_BYPASS_DEV=false

# ============================================================
# Post-deploy checklist (manual steps):
# 1. npx convex deploy
# 2. npm run convex:seed
# 3. Clerk Dashboard → JWT template `convex`
# 4. vercel --prod  (or push to main if CI connected)
# ============================================================
