# --- Required (Production + Preview) ---

NEXT_PUBLIC_CONVEX_URL="https://your-deployment.convex.cloud"
CONVEX_DEPLOYMENT="prod:your-deployment"
CONVEX_DEPLOY_KEY=""

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_..."
CLERK_SECRET_KEY="sk_live_..."
CLERK_JWT_ISSUER_DOMAIN="https://your-clerk-domain.clerk.accounts.dev"

NEXT_PUBLIC_APP_URL="https://fundingpro.uz"
NEXT_PUBLIC_APP_NAME="FundingPro"

RESEND_API_KEY="re_xxxxxxxxx"
RESEND_FROM_EMAIL="info@fundingpro.uz"

ADMIN_EMAILS="info@fundingpro.uz"

# --- Recommended ---

AI_PROVIDER="mock"
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""

CORS_ALLOWED_ORIGINS="https://fundingpro.uz"

# --- Payments (keep disabled until Uzum sandbox pass) ---

PAYMENTS_ENABLED=false
PAYMENT_INTEGRATION_STATUS=pending_integration
PAYMENT_PROVIDER=uzum
USD_UZS_RATE=12800

UZUM_MERCHANT_SERVICE_ID=
UZUM_MERCHANT_LOGIN=
UZUM_MERCHANT_PASSWORD=

UZUM_CHECKOUT_BASE_URL=https://api.uzumbank.uz
UZUM_CHECKOUT_TERMINAL_ID=
UZUM_CHECKOUT_SECRET=
UZUM_CHECKOUT_RETURN_URL=https://fundingpro.uz/dashboard/subscription/return
# Production webhook base for npm run uzum:webhooks
# UZUM_WEBHOOK_BASE_URL=https://fundingpro.uz

# --- Do NOT set in production ---

# ADMIN_BYPASS_DEV=false

# ============================================================
# Post-deploy checklist (manual steps):
# 1. npx convex deploy
# 2. npm run convex:seed
# 3. Clerk Dashboard → JWT template `convex`
# 4. vercel --prod  (or push to main if CI connected)
# ============================================================
