{
  "name": "fundingpro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "convex:dev": "npx convex dev",
    "convex:codegen": "npx convex codegen",
    "convex:seed": "node scripts/convex-seed.mjs",
    "convex:export-pg": "node scripts/export-pg-to-convex.mjs",
    "convex:import-pg": "node scripts/import-to-convex.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "setup": "npx convex dev",
    "test": "node --import tsx --test tests/*.test.mjs",
    "test:smoke": "node scripts/smoke-test.mjs",
    "test:integration": "node scripts/api-auth-integration.mjs",
    "test:e2e": "playwright test",
    "uzum:check": "node scripts/uzum-go-live.mjs",
    "uzum:sandbox": "node scripts/uzum-sandbox-e2e.mjs",
    "payme:sandbox": "node scripts/payme-sandbox.mjs",
    "click:sandbox": "node scripts/click-sandbox.mjs",
    "payments:check": "node scripts/payments-check.mjs",
    "uzum:checkout-mock": "node scripts/uzum-checkout-mock-e2e.mjs",
    "uzum:enable": "node scripts/uzum-enable-payments.mjs",
    "uzum:webhooks": "node -e \"const u=process.env.UZUM_WEBHOOK_BASE_URL||'https://fundingpro.uz';['check','create','confirm','reverse','status'].forEach(e=>console.log('POST '+u.replace(/\\/$/,'')+'/api/v1/payments/uzum/'+e))\"",
    "pilot:check": "node scripts/pilot-check.mjs",
    "telegram:digest": "node scripts/telegram-grants-digest.mjs",
    "deploy:check": "node scripts/deploy-check.mjs",
    "deploy:prep": "npm run check && npm run lint && npm run deploy:check && npm run build",
    "deploy:env": "node scripts/vercel-env-push.mjs",
    "deploy:production": "node scripts/production-next-steps.mjs",
    "deploy:setup-env": "node scripts/setup-production-env.mjs",
    "production:readiness": "node scripts/production-readiness.mjs",
    "check": "npm run typecheck && npm test",
    "security:audit": "node scripts/security-audit-orchestrator.mjs",
    "security:probe": "node scripts/security-api-probe.mjs",
    "security:probe:prod": "SMOKE_BASE_URL=https://www.fundingpro.uz node scripts/security-api-probe.mjs",
    "contract:mobile-api": "node scripts/mobile-api-contract.mjs"
  },
  "dependencies": {
    "@clerk/nextjs": "5.7.6",
    "@fundingpro/shared": "^0.1.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.42.0",
    "convex-helpers": "^0.1.120",
    "lucide-react": "^1.16.0",
    "next": "14.2.35",
    "nodemailer": "^9.0.1",
    "pg": "^8.20.0",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^6.12.3",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^2.0.0",
    "@playwright/test": "^1.51.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
