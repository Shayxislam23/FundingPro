# API (no trailing slash on /api/v1)
EXPO_PUBLIC_API_URL=https://www.fundingpro.uz/api/v1

# Clerk — same application as fundingpro web
# JWT template name: convex (used for Bearer auth to /api/v1)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key

# Clerk Dashboard → Redirect URLs (required for mobile sign-in):
#   fundingpro://auth/callback
# Production App Links (after Vercel APPLE_TEAM_ID + ANDROID_RELEASE_SHA256):
#   https://www.fundingpro.uz/mobile/auth/callback
# App scheme is defined in app.json ("fundingpro")

# Optional
EXPO_PUBLIC_SENTRY_DSN=

# Expo push (configured in Convex dashboard as EXPO_ACCESS_TOKEN for server-side sends)
