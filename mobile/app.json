{
  "expo": {
    "name": "FundingPro",
    "slug": "fundingpro",
    "version": "0.3.0",
    "orientation": "portrait",
    "scheme": "fundingpro",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "uz.fundingpro.app"
    },
    "android": {
      "package": "uz.fundingpro.app",
      "adaptiveIcon": {
        "backgroundColor": "#008A2E",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#008A2E"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "57edb446-5583-4f1a-9540-6b812beb5467"
      }
    },
    "owner": "shayxislam"
  }
}
