{
  "name": "fundingpro-monorepo",
  "private": true,
  "workspaces": [
    "fundingpro",
    "mobile",
    "packages/*"
  ],
  "overrides": {
    "postcss": "^8.5.10",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "next": "15.5.19",
    "@clerk/nextjs": "7.5.9",
    "eslint-config-next": "15.5.19"
  },
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "mobile:start": "npm run start --workspace=mobile",
    "mobile:typecheck": "npm run typecheck --workspace=mobile",
    "contract:mobile-api": "node fundingpro/scripts/mobile-api-contract.mjs",
    "mobile:dev": "bash mobile/scripts/dev-client.sh",
    "mobile:rebuild-ios": "bash mobile/scripts/rebuild-ios-dev-client.sh",
    "convex:seed:prod": "node fundingpro/scripts/seed-production-safe.mjs"
  }
}
