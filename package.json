{
  "name": "fundingpro-monorepo",
  "private": true,
  "dependencies": {
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "workspaces": [
    "fundingpro",
    "mobile",
    "packages/*"
  ],
  "overrides": {
    "postcss": "^8.5.10",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "next": {
      "postcss": "^8.5.10"
    },
    "@clerk/nextjs": "7.5.9",
    "@clerk/expo": "3.7.5",
    "@clerk/clerk-js": "6.25.3",
    "@clerk/shared": "4.25.3",
    "@clerk/backend": "3.8.4",
    "@clerk/react": "6.12.3",
    "@clerk/clerk-react": "5.61.8",
    "eslint-config-next": "15.5.19",
    "ws": "8.21.0",
    "viem": {
      "ws": "8.21.0"
    },
    "uuid": "^11.1.1",
    "js-cookie": "^3.0.6",
    "eslint-config-expo": {
      "eslint": "9.39.4"
    },
    "eslint": "9.39.4"
  },
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "mobile:start": "npm run start --workspace=mobile",
    "mobile:typecheck": "npm run typecheck --workspace=mobile",
    "contract:mobile-api": "node fundingpro/scripts/mobile-api-contract.mjs",
    "mobile:dev": "bash mobile/scripts/dev-client.sh",
    "mobile:rebuild-ios": "bash mobile/scripts/rebuild-ios-dev-client.sh",
    "mobile:maestro": "npm run maestro --workspace=@fundingpro/mobile",
    "convex:seed:prod": "node fundingpro/scripts/seed-production-safe.mjs"
  }
}
